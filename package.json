    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "js-yaml": "^4.1.0",
    "morgan": "^1.10.1",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.25.28"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/js-yaml": "^4.0.9",
    "@types/morgan": "^1.9.10",
    "@types/node": "^24.0.1",
    "@types/supertest": "^6.0.3",
    "@types/swagger-ui-express": "^4.1.8",
    "supertest": "^7.1.4",
